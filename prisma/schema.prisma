generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ExperienceType {
  EDUCATION
  WORK
}

enum SkillCategory {
  FRONTEND
  BACKEND
  TOOLS
}

model Project {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  description String   @db.Text
  thumbnail   String?
  githubUrl   String?
  liveUrl     String?
  techStack   String[]
  isFeatured  Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

model Experience {
  id          String         @id @default(uuid())
  type        ExperienceType
  position    String
  institution String
  description String?        @db.Text
  startDate   DateTime
  endDate     DateTime?
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("experiences")
}

model Skill {
  id        String        @id @default(uuid())
  name      String
  icon      String?
  category  SkillCategory
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("skills")
}

model Message {
  id        String   @id @default(uuid())
  name      String
  email     String
  body      String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("messages")
}
